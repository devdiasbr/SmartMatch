# ──────────────────────────────────────────────
# Frontend (Vite) — copiado para .env.local
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opcional: override da URL base da API para dev local apontando para Supabase
# (por padrão usa /api/make-server-68454e9b em produção)
# VITE_API_URL=https://your-project.supabase.co/functions/v1/make-server-68454e9b

# ──────────────────────────────────────────────
# Backend (Vercel Edge Function)
# Configure no painel: Vercel Dashboard > Settings > Environment Variables
# NÃO coloque valores reais neste arquivo.
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
RESEND_API_KEY=your-resend-api-key
